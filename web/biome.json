{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["**", "!dist", "!node_modules", "!pnpm-lock.yaml"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "a11y": {
        "preset": "all"
      },
      "complexity": {
        "preset": "all",
        "noExcessiveLinesPerFunction": "off",
        "noExcessiveCognitiveComplexity": "off"
      },
      "nursery": {
        "preset": "all"
      },
      "performance": {
        "preset": "all",
        "noJsxPropsBind": "off",
        "useSolidForComponent": "off"
      },
      "security": {
        "preset": "all",
        "noSecrets": "off"
      },
      "style": {
        "preset": "all",
        "noTernary": "off",
        "noMagicNumbers": "off",
        "noHexColors": "off",
        "noJsxLiterals": "off",
        "useComponentExportOnlyModules": "off",
        "useNamingConvention": "off",
        "useExportsLast": "off",
        "useConsistentMemberAccessibility": "off",
        "noExcessiveLinesPerFile": "off"
      },
      "suspicious": {
        "preset": "all",
        "noReactSpecificProps": "off"
      },
      "correctness": {
        "preset": "all",
        "useQwikValidLexicalScope": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "overrides": [
    {
      "includes": ["src/types.ts"],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["src/i18n.tsx"],
      "linter": {
        "rules": {
          "security": {
            "noSecrets": "off"
          },
          "style": {
            "useExportsLast": "off"
          }
        }
      }
    }
  ]
}
