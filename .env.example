# Required: your Dizzylab login credentials.
DIZZYSYNC_USERNAME=your_username_here
DIZZYSYNC_PASSWORD=your_password_here

# Recommended: set a long random API key for the web/API control server.
# If left empty, DizzySync auto-generates one on first non-loopback startup and saves it in /config/config.toml.
DIZZYSYNC_API_KEY=

# Optional host settings.
DIZZYSYNC_PORT=8787
DIZZYSYNC_DATA_DIR=./DizzySync
